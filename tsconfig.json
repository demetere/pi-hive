{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "types": []
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.mjs",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "ui/web/node_modules",
    "ui/web/dist"
  ]
}
