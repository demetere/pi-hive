{
  "name": "pi-hive",
  "version": "0.1.0",
  "description": "Hierarchical multi-agent orchestration extension for the Pi coding agent, with a live Solid + Vite telemetry dashboard.",
  "type": "module",
  "author": "Demetre Dzmanashvili <demetredzmanashvili@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/demetere/pi-hive.git"
  },
  "bugs": {
    "url": "https://github.com/demetere/pi-hive/issues"
  },
  "homepage": "https://github.com/demetere/pi-hive#readme",
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.14"
  },
  "main": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://raw.githubusercontent.com/demetere/pi-hive/main/docs/assets/dashboard-overview.png"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "index.ts",
    "src/",
    "ui/web/dist/",
    "ui/review/src/",
    "ui/review/dist/",
    "ui/review/vendor.json",
    "scripts/build-review-bundle.mjs",
    "scripts/check-package-budgets.mjs",
    "scripts/check-review-vendor.mjs",
    "README.md",
    "SECURITY.md",
    "SETUP.md"
  ],
  "scripts": {
    "build:dashboard": "just dashboard-build",
    "build:review": "just review-build",
    "typecheck": "just typecheck",
    "typecheck:core": "just typecheck-core",
    "typecheck:bun": "just typecheck-bun",
    "typecheck:tests": "just typecheck-tests",
    "typecheck:dashboard": "just dashboard-typecheck",
    "lint": "just lint",
    "test": "just test",
    "verify:dashboard": "just dashboard-verify",
    "verify:package": "just verify-package",
    "ci": "just ci",
    "prepack": "just prepack",
    "prepublishOnly": "just prepublish"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": false
    },
    "@earendil-works/pi-tui": {
      "optional": false
    },
    "typebox": {
      "optional": false
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@eslint/js": "^10.0.1",
    "@plannotator/pi-extension": "0.23.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "c8": "^11.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "@fission-ai/openspec": "1.6.0"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "agents",
    "orchestration",
    "telemetry",
    "observability"
  ],
  "license": "MIT"
}
