{
  "name": "pi-hive",
  "version": "1.0.0",
  "description": "Config-first workflow orchestration for Pi with linked sessions, capability policy, artifact adapters, and a local dashboard.",
  "type": "module",
  "author": "Demetre Dzmanashvili <demetredzmanashvili@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/demetere/pi-hive.git"
  },
  "bugs": {
    "url": "https://github.com/demetere/pi-hive/issues"
  },
  "homepage": "https://github.com/demetere/pi-hive#readme",
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.14"
  },
  "os": [
    "linux"
  ],
  "main": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "image": "https://raw.githubusercontent.com/demetere/pi-hive/main/docs/assets/dashboard-overview.png"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "CHANGELOG.md",
    "THIRD_PARTY_NOTICES.md",
    "index.ts",
    "src/",
    "schemas/",
    "ui/web/dist/",
    "examples/",
    "scripts/check-package-budgets.mjs",
    "scripts/check-licenses.mjs",
    "README.md",
    "SECURITY.md",
    "SETUP.md"
  ],
  "scripts": {
    "build:dashboard": "just dashboard-build",
    "build:config-schemas": "just config-schema-build",
    "typecheck": "just typecheck",
    "typecheck:core": "just typecheck-core",
    "typecheck:bun": "just typecheck-bun",
    "typecheck:tests": "just typecheck-tests",
    "typecheck:dashboard": "just dashboard-typecheck",
    "lint": "just lint",
    "test": "just test",
    "verify:dashboard": "just dashboard-verify",
    "verify:config-schemas": "just config-schema-verify",
    "verify:package": "just verify-package",
    "verify:install": "just verify-packed-install",
    "verify:licenses": "just verify-licenses",
    "verify:release": "just release-verify",
    "release:artifacts": "just release-artifacts",
    "ci": "just ci",
    "prepack": "just prepack",
    "prepublishOnly": "just prepublish"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": false
    },
    "@earendil-works/pi-tui": {
      "optional": false
    },
    "typebox": {
      "optional": false
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@eslint/js": "^9.39.5",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.1",
    "ajv": "^8.20.0",
    "c8": "^10.1.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "@fission-ai/openspec": "1.6.0",
    "yaml": "2.9.0"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "agents",
    "orchestration",
    "telemetry",
    "observability"
  ],
  "license": "MIT"
}
