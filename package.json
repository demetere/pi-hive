{
  "name": "pi-hive",
  "version": "0.1.0",
  "description": "Hierarchical multi-agent orchestration extension for the Pi coding agent, with a live Solid + Vite telemetry dashboard.",
  "type": "module",
  "author": "Demetre Dzmanashvili <demetredzmanashvili@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/demetere/pi-hive.git"
  },
  "bugs": {
    "url": "https://github.com/demetere/pi-hive/issues"
  },
  "homepage": "https://github.com/demetere/pi-hive#readme",
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "main": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "pi": {
    "extensions": ["./index.ts"],
    "image": "https://raw.githubusercontent.com/demetere/pi-hive/main/docs/assets/dashboard-overview.png"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "index.ts",
    "src/",
    "ui/web/dist/",
    "ui/review/src/",
    "ui/review/dist/",
    "scripts/build-review-bundle.mjs",
    "scripts/check-package-budgets.mjs",
    "README.md",
    "SECURITY.md",
    "SETUP.md"
  ],
  "scripts": {
    "build:dashboard": "just dashboard-build",
    "build:review": "just review-build",
    "typecheck:core": "just typecheck-core",
    "typecheck:dashboard": "just dashboard-typecheck",
    "test": "just test",
    "verify:dashboard": "just dashboard-verify",
    "verify:package": "just verify-package",
    "ci": "just ci",
    "prepack": "just prepack",
    "prepublishOnly": "just prepublish"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": { "optional": false },
    "@earendil-works/pi-tui": { "optional": false },
    "typebox": { "optional": false }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3"
  },
  "dependencies": {
    "@fission-ai/openspec": "1.5.0"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "agents",
    "orchestration",
    "telemetry",
    "observability"
  ],
  "license": "MIT"
}
