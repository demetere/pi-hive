                    },
                    "max-agent-turns": {
                      "maximum": 9007199254740991,
                      "minimum": 1,
                      "type": "integer"
                    },
                    "max-tool-calls": {
                      "maximum": 9007199254740991,
                      "minimum": 1,
                      "type": "integer"
                    },
                    "token-budget": {
                      "maximum": 9007199254740991,
                      "minimum": 1,
                      "type": "integer"
                    }
                  },
                  "type": "object"
                },
                "capabilities": {
                  "additionalProperties": false,
